# Shellcheck конфигурация
# https://github.com/koalaman/shellcheck/blob/master/shellcheck.1.md#rc-files

# Игнорируемые правила (при необходимости):
# SC1091 - не проверять source файлов которые не существуют в репозитории
# SC2086 - намеренное отсутствие кавычек (разрешено в проекте)
# SC2034 - неиспользуемые переменные (часто используются в тестах для mock)
# SC2120 - cat без аргументов (используется в тестах)
# SC2178 - переменная использовалась как массив, затем как строка (в тестах)
# SC1111 - unicode кавычки (проблемы кодировки в тестах)
# SC2096 - shebang с несколькими параметрами (ложные срабатывания на Windows)
exclude=SC1091,SC2086,SC2034,SC2120,SC2178,SC1111,SC2096

# Минимальная версия bash
shell=bash
