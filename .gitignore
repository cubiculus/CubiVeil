*.tmp
*.bak
*.swp
*~

# --- Archives ---
*.tar.gz
*.zip

# --- Python ---
*.py[cod]
*$py.class
*.so
.Python
__pycache__/
*.pyc
.pytest_cache/
ssh_connect.py
venv/
env/
ENV/

# --- Pre-commit ---
.pre-commit-cache/
.secrets.baseline

# --- IDE ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
Thumbs.db

